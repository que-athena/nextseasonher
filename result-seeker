<style>
:root {
  --bg: #560000;
  --surface: #6B1414;
  --surface-deep: #3D0000;
  --burgundy: #560000;
  --burgundy-deep: #3D0000;
  --cream: #F1EADA;
  --cream-dim: rgba(241, 234, 218, 0.82);
  --cream-faint: rgba(241, 234, 218, 0.5);
  --sage: #B6BEAA;
  --sage-dim: rgba(182, 190, 170, 0.55);
