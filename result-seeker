/* ── HEADER ──────────────────────────────── */
.page-header {
  padding: 32px 32px 24px;
  text-align: center;
  border-bottom: 1px solid var(--hairline);
}

.brand {
  font-size: 11px;
  font-weight: 400;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--sage);
}

/* ── HERO ────────────────────────────────── */
.hero {
  padding: 80px 32px 56px;
  max-width: 720px;
  margin: 0 auto;
  text-align: center;
  opacity: 0;
  animation: fadeUp 1s ease 0.2s forwards;
}

@keyframes fadeUp {
