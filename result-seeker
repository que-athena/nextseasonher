<script>
// Read readiness from URL parameter and show the correct CTA
(function() {
  const params = new URLSearchParams(window.location.search);
  const readiness = params.get('readiness') || 'ReadyNow';

  const readyNowEl = document.getElementById('cta-ready-now');
  const readyLaterEl = document.getElementById('cta-ready-later');

  if (readiness === 'ReadyLater') {
    readyLaterEl.style.display = 'block';
  } else {
    // Default to Ready Now if param is missing or anything else
    readyNowEl.style.display = 'block';
  }
})();
</script>

