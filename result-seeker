  letter-spacing: 0.02em;
}

.hero-archetype {
  font-family: 'Cormorant Garamond', serif;
  font-weight: 400;
  font-size: clamp(56px, 11vw, 96px);
  line-height: 1.02;
  letter-spacing: -0.015em;
