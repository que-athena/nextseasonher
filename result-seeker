  margin: 0 auto;
  font-weight: 400;
}

/* ── CONTENT SECTIONS ────────────────────── */
.content {
  max-width: 640px;
  margin: 0 auto;
  padding: 64px 32px;
}

.section {
  margin-bottom: 80px;
}

.section:last-child {
  margin-bottom: 0;
}

.section-eyebrow {
  font-size: 10px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--sage);
  margin-bottom: 24px;
  display: flex;
  align-items: center;
  gap: 16px;
}

.section-eyebrow::after {
